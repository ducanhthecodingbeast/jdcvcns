                <mxCell id="notes" value="Key design progression&lt;br&gt;&lt;br&gt;1.0: simple dense baseline with title-based JD sample&lt;br&gt;2.0: PostgreSQL pgvector JD embedding upload&lt;br&gt;2.1: clean dense dot-product CV-to-JD baseline&lt;br&gt;2.2: two-phase retrieval, then hybrid dense/lexical rerank&lt;br&gt;2.3: direct hybrid dense/lexical ranking&lt;br&gt;3.0: Qdrant-based BGE-M3 hybrid vector retrieval&lt;br&gt;4.0: Qdrant recall plus ViRanker cross-encoder reranking&lt;br&gt;6.x: JobBERT dense cosine/dot-product and BM25 lexical baselines" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;align=left;spacingLeft=14;" parent="versionsContainer" vertex="1">
                    <mxGeometry x="1590" y="365" width="740" height="260" as="geometry"/>
                </mxCell>
                <mxCell id="dbnotes" value="Database contracts&lt;br&gt;&lt;br&gt;testingresult.py stores experiment metadata and ranked matches:&lt;br&gt;- test_runs: run name, algorithm, model, params, dataset metadata&lt;br&gt;- run_cvs / run_jds: payload snapshots and text content&lt;br&gt;- run_matches: cv_id, jd_id, rank, score, metadata&lt;br&gt;&lt;br&gt;dotpdtesting2.0.py additionally creates job_descriptions with embedding vector(1024)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;align=left;spacingLeft=14;" parent="versionsContainer" vertex="1">
                    <mxGeometry x="1590" y="650" width="740" height="205" as="geometry"/>
