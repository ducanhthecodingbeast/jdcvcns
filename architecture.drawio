                <mxCell id="v10" value="1.0/dotpdtesting1.0.py&lt;br&gt;&lt;br&gt;Input: jd.csv + cv.csv + generated mock CVs&lt;br&gt;Sampling: top 30 job titles, 2 JDs per title&lt;br&gt;Model: AITeamVN/Vietnamese_Embedding_v2&lt;br&gt;Algorithm: JD-to-CV dense dot product&lt;br&gt;Output: top_k run_matches" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf2ff;strokeColor=#6c8ebf;fontSize=13;align=left;spacingLeft=12;" parent="versionsContainer" vertex="1">
                    <mxGeometry x="35" y="85" width="300" height="175" as="geometry"/>
                </mxCell>
                <mxCell id="v20" value="2.0/dotpdtesting2.0.py&lt;br&gt;&lt;br&gt;Purpose: upload JD embeddings, not full CV/JD matching&lt;br&gt;Input: jd.csv or JOB_DATA_FINAL.csv&lt;br&gt;Model: AITeamVN/Vietnamese_Embedding_v2&lt;br&gt;Algorithm: encode JD searchable_text&lt;br&gt;Output: job_descriptions rows with vector(1024)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffeaea;strokeColor=#b85450;fontSize=13;align=left;spacingLeft=12;" parent="versionsContainer" vertex="1">
                    <mxGeometry x="370" y="85" width="310" height="175" as="geometry"/>
                </mxCell>
                <mxCell id="v21" value="2.0/dotpdtesting2.1.py&lt;br&gt;&lt;br&gt;Input: sample up to 600 CVs, 100 JDs&lt;br&gt;Model: AITeamVN/Vietnamese_Embedding_v2&lt;br&gt;Cache: cv_embeddings_v2.npy + jd_embeddings_v2.npy&lt;br&gt;Algorithm: CV-to-JD dense dot product&lt;br&gt;Output: top_k run_matches" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf2ff;strokeColor=#6c8ebf;fontSize=13;align=left;spacingLeft=12;" parent="versionsContainer" vertex="1">
                    <mxGeometry x="715" y="85" width="310" height="175" as="geometry"/>
                </mxCell>
                <mxCell id="v22" value="2.0/dotpdtesting2.2.py&lt;br&gt;&lt;br&gt;Input: same sampled CV/JD set as 2.1&lt;br&gt;Stage 1: Vietnamese_Embedding_v2 dot product top 30&lt;br&gt;Stage 2: BGE-M3 dense cosine + TF-IDF lexical&lt;br&gt;Algorithm: two-phase hybrid rerank&lt;br&gt;Output: top_k run_matches with v2, bge_dense, lexical metadata" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff6df;strokeColor=#d6b656;fontSize=13;align=left;spacingLeft=12;" parent="versionsContainer" vertex="1">
                    <mxGeometry x="1060" y="85" width="330" height="175" as="geometry"/>
                </mxCell>
                <mxCell id="v23" value="2.0/dotpdtesting2.3.py&lt;br&gt;&lt;br&gt;Input: same sampled CV/JD set as 2.1&lt;br&gt;Model: BAAI/bge-m3 + TF-IDF&lt;br&gt;Algorithm: direct hybrid over all sampled JDs&lt;br&gt;Score: 0.5 * dense cosine + 0.5 * lexical cosine&lt;br&gt;Output: top_k run_matches with bge_dense and lexical metadata" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff6df;strokeColor=#d6b656;fontSize=13;align=left;spacingLeft=12;" parent="versionsContainer" vertex="1">
                    <mxGeometry x="1425" y="85" width="330" height="175" as="geometry"/>
                </mxCell>
                <mxCell id="v30" value="3.0/bgmewdranttesting3.0.py&lt;br&gt;&lt;br&gt;Input: load_datasets() from shared Data&lt;br&gt;Model: BAAI/bge-m3 via FlagEmbedding&lt;br&gt;Index: Qdrant dense + sparse + ColBERT vectors&lt;br&gt;Search: sparse + dense prefetch, ColBERT query&lt;br&gt;Output: top_k run_matches, source=qdrant_bgem3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf8ea;strokeColor=#82b366;fontSize=13;align=left;spacingLeft=12;" parent="versionsContainer" vertex="1">
                    <mxGeometry x="1790" y="85" width="330" height="175" as="geometry"/>
                </mxCell>
                <mxCell id="v40" value="4.0/virankertesting4.0.py&lt;br&gt;&lt;br&gt;Input: load_datasets() from shared Data&lt;br&gt;Recall: BGE-M3 dense + sparse in Qdrant&lt;br&gt;Fusion: Qdrant RRF over candidate pool&lt;br&gt;Rerank: namdp-ptit/ViRanker cross-encoder&lt;br&gt;Output: top_k run_matches + optional CSV summary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffeaea;strokeColor=#b85450;fontSize=13;align=left;spacingLeft=12;" parent="versionsContainer" vertex="1">
